generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "windows"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  nome      String
  email     String   @unique
  senha     String
  telefone  String?
  endereco  String?
  rua       String?
  numero    String?
  bairro    String?
  cidade    String?
  cep       String?
  tipo      String   @default("cliente")
  pedidos   Order[]
  createdAt DateTime @default(now()) @map("criado_em")

  @@map("usuarios")
}

model Category {
  id       Int       @id @default(autoincrement())
  nome     String
  slug     String    @unique
  icone    String    @default("package")
  products Product[]

  @@map("categorias")
}

model Product {
  id          Int      @id @default(autoincrement())
  categoriaId Int      @map("categoria_id")
  categoria   Category @relation(fields: [categoriaId], references: [id])
  nome        String
  slug        String   @unique
  descricao   String   @default("")
  preco       Float
  estoque     Int      @default(0)
  imagem      String   @default("sem-imagem.png")
  destaque    Int      @default(0)
  ativo       Int      @default(1)
  createdAt   DateTime @default(now()) @map("criado_em")
  items       OrderItem[]

  @@map("produtos")
}

model Order {
  id               Int         @id @default(autoincrement())
  usuarioId        Int?        @map("usuario_id")
  usuario          User?       @relation(fields: [usuarioId], references: [id])
  nomeCliente      String      @map("nome_cliente")
  telefone         String
  endereco         String
  rua              String?
  numero           String?
  bairro           String?
  cidade           String?
  cep              String?
  formaPagamento   String      @map("forma_pagamento")
  status           String      @default("pendente")
  total            Float
  observacoes      String?
  createdAt        DateTime    @default(now()) @map("criado_em")
  items            OrderItem[]

  @@map("pedidos")
}

model OrderItem {
  id             Int     @id @default(autoincrement())
  pedidoId       Int     @map("pedido_id")
  pedido         Order   @relation(fields: [pedidoId], references: [id], onDelete: Cascade)
  produtoId      Int     @map("produto_id")
  produto        Product @relation(fields: [produtoId], references: [id])
  quantidade     Int
  precoUnitario  Float   @map("preco_unitario")

  @@map("itens_pedido")
}
